        this.ObjMAOAF.ERRDiscoverAuthFee = 0m;

        ERRVisaDiscount.Value = 0m;
        ERRVisaNonQualFee.Value = 0m;
        ERRVisaAuthFee.Value = 0m;

        ERRMCDiscount.Value = 0m;
        ERRMCNonQualFee.Value = 0m;
        ERRMCAuthFee.Value = 0m;

        ERRDiscoverDiscount.Value = 0m;
        ERRDiscoverNonQualFee.Value = 0m;
        ERRDiscoverAuthFee.Value = 0m;
    }

