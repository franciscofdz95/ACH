    protected void init_fee_mapping()
    {

        // we are mapping fields from table MerchantAppsOnlineAgentFees to sp_SelectAgentResidualReportItems 

        this.diFeeMapping = new Dictionary<string, string>();

        // fee mapping: NOTE: 
        // if value is an empty string, then there is no mapping. 
        // if value is a guid, then there is a mapping. 
        // if value is the name of the key then we pull from the default.
        this.diFeeMapping.Add("VisaQualRate", "");
        this.diFeeMapping.Add("VisaQualFee", "CF5DA10D-13F6-4A9F-95C0-7553C23FAA9E");
        this.diFeeMapping.Add("VisaMidQualRate", "");
        this.diFeeMapping.Add("VisaMidQualFee", "CF5DA10D-13F6-4A9F-95C0-7553C23FAA9E");
        this.diFeeMapping.Add("VisaNonQualRate", "");
        this.diFeeMapping.Add("VisaNonQualFee", "CF5DA10D-13F6-4A9F-95C0-7553C23FAA9E");
        this.diFeeMapping.Add("MCQualRate", "");
        this.diFeeMapping.Add("MCQualFee", "CF5DA10D-13F6-4A9F-95C0-7553C23FAA9E");
        this.diFeeMapping.Add("MCMidQualRate", "");
        this.diFeeMapping.Add("MCMidQualFee", "CF5DA10D-13F6-4A9F-95C0-7553C23FAA9E");
        this.diFeeMapping.Add("MCNonQualRate", "");
        this.diFeeMapping.Add("MCNonQualFee", "CF5DA10D-13F6-4A9F-95C0-7553C23FAA9E");
        this.diFeeMapping.Add("DiscoverQualRate", "");
        this.diFeeMapping.Add("DiscoverQualFee", "CF5DA10D-13F6-4A9F-95C0-7553C23FAA9E");
        this.diFeeMapping.Add("DiscoverMidQualRate", "");
        this.diFeeMapping.Add("DiscoverMidQualFee", "CF5DA10D-13F6-4A9F-95C0-7553C23FAA9E");
        this.diFeeMapping.Add("DiscoverNonQualRate", "");
        this.diFeeMapping.Add("DiscoverNonQualFee", "CF5DA10D-13F6-4A9F-95C0-7553C23FAA9E");
        this.diFeeMapping.Add("VoiceAuthorizationFee", "");
        this.diFeeMapping.Add("AVSVoiceAuthorizationFee", "");
        this.diFeeMapping.Add("VruARUFee", "");
        this.diFeeMapping.Add("ChargebackFee", "BF736941-A28A-4FAA-8EA7-4212B494F7B2");
        this.diFeeMapping.Add("ACHBatchFee", "27721C71-88F9-4865-8290-177F57822B97");
        this.diFeeMapping.Add("MonthlyMinimumFee", "");
        this.diFeeMapping.Add("ServiceFee", "E18A27AD-2C7C-44D8-9879-E5FE2CE0BA2F");
        this.diFeeMapping.Add("RetrievalRequestFee", "C01F33FA-4BFF-475B-AB82-10B172D1F8DC");
        this.diFeeMapping.Add("MerchantClubFee", "F04DE180-402C-49E4-B2FB-F261A0B0B84E");
        this.diFeeMapping.Add("ApplicationFee", "C4956B39-E74C-4AE8-9DA6-A012C0BEE8D1");
        this.diFeeMapping.Add("WirelessSetupFee", "WirelessSetupFee");
        this.diFeeMapping.Add("WirelessTransactionFee", "WirelessTransactionFee");
        this.diFeeMapping.Add("WirelessDataMonthlyFee", "WirelessDataMonthlyFee");
        this.diFeeMapping.Add("GatewaySetupFee", "21C9AF94-F4E1-4845-99D8-A9FE30D9D987");
        this.diFeeMapping.Add("GatewayMonthlyFee", "3BDD21EA-B69D-48F1-ACA9-F73598E031F2");
        this.diFeeMapping.Add("GatewayTransactionFee", "979932D8-7E69-40E2-ADC0-08EE18A0BEF5");
        this.diFeeMapping.Add("ERRVisaDiscount", "");
        this.diFeeMapping.Add("ERRVisaNonQualFee", "");
        this.diFeeMapping.Add("ERRVisaAuthFee", "");
        this.diFeeMapping.Add("ERRMCDiscount", "");
        this.diFeeMapping.Add("ERRMCNonQualFee", "");
        this.diFeeMapping.Add("ERRMCAuthFee", "");
        this.diFeeMapping.Add("ERRDiscoverDiscount", "");
        this.diFeeMapping.Add("ERRDiscoverNonQualFee", "");
        this.diFeeMapping.Add("ERRDiscoverAuthFee", "");
        this.diFeeMapping.Add("InterchangePlus", "");
        this.diFeeMapping.Add("InterchangePerItem", "");

        this.diFeeMapping.Add("DebitAccessFee", "9F104D2B-90AF-4BB7-A551-40A4C652582D");
        this.diFeeMapping.Add("DebitTransactionFee", "17204874-52E8-4CEF-9F4F-02AF1E560347");
        this.diFeeMapping.Add("DebitPercentage", "");


        DataAgent data = DataAccess.DataAgentDao;
        DataSet ds = data.GetResidualReportItemsDS(UserSessions.CurrentAgent.AgentUID);

        this.diFees = new Dictionary<string, AgentFee>();
        if (ds != null && ds.Tables.Count == 1 && ds.Tables[0].Rows.Count > 0)
        {
            foreach (DataRow dr in ds.Tables[0].Rows)
            {
                AgentFee objAF = new AgentFee();
                objAF.AgentUID = dr["AgentUID"].ToString();
                objAF.Cost = Convert.ToDecimal(dr["Cost"]);
                objAF.Enabled = Convert.ToBoolean(dr["Enabled"]);
                objAF.UID = dr["UID"].ToString().Trim().ToUpper();
                this.diFees.Add(objAF.UID, objAF);
            }

        }

        // run thru the default fees and set them into the mapping and the object.
        foreach (KeyValuePair<string, decimal> kvp in this.diDefaultFees)
        {
            // only write to the mapping if its empty (in other words, database value has precedence then soft values)
            if (kvp.Value != 0m && this.diFeeMapping.ContainsKey(kvp.Key) && this.diFeeMapping[kvp.Key] == "")
            {
                this.diFeeMapping[kvp.Key] = kvp.Key;
                this.diFees.Add(kvp.Key, new AgentFee("", "", 0, kvp.Value, true, DateTime.Now, "", "", DateTime.Now));
            }

        }

    }

    // default return value is '0.0'
    public decimal GetFee(string fee_name)
    {
        if (this.diFeeMapping == null || this.diFees == null)
        {
            this.init_fee_mapping();
        }

        decimal ret = 0.0m;
        if (this.diFeeMapping.ContainsKey(fee_name))
        {
            string uid = this.diFeeMapping[fee_name];

            if (uid != "" && this.diFees.ContainsKey(uid) && this.diFees[uid].Enabled == true)
            {
                ret = this.diFees[uid].Cost;
            }
        }

        return ret;
    }

