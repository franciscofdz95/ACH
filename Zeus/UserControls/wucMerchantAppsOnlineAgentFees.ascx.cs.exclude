    public void SetControlEditMode(bool isEdit)
    {
        FormHandler.SetControlEditMode(pnlDetail, isEdit);
    }

    protected void cbTieredPricing_SelectedIndexChanged(object sender, EventArgs e)
    {
        pnlCardType.Visible = false;
        pnlInterchange.Visible = false;
        pnlErr.Visible = false;

        if (PricingType.SelectedValue == "t")
        {
            pnlCardType.Visible = true;

        }
        else if (PricingType.SelectedValue == "i")
        {
            pnlInterchange.Visible = true;

        }
        else if (PricingType.SelectedValue == "e")
        {
            pnlErr.Visible = true;

        }

    }

    protected void SetZeros_Interchange()
    {
        this.ObjMAOAF.InterchangePlus = 0m;
        this.ObjMAOAF.InterchangePerItem = 0m;

        InterchangePlus.Value = 0m;
        InterchangePerItem.Value = 0m;
    }

    protected void SetZeros_ERR()
    {
        this.ObjMAOAF.ERRVisaDiscount = 0m;
        this.ObjMAOAF.ERRVisaNonQualFee = 0m;
        this.ObjMAOAF.ERRVisaAuthFee = 0m;

        this.ObjMAOAF.ERRMCDiscount = 0m;
        this.ObjMAOAF.ERRMCNonQualFee = 0m;
        this.ObjMAOAF.ERRMCAuthFee = 0m;

        this.ObjMAOAF.ERRDiscoverDiscount = 0m;
