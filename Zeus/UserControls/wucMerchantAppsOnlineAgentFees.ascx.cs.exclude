    protected void cbEnableWireless_CheckedChanged(object sender, EventArgs e)
    {
        if (cbEnableWireless.Checked)
        {
            pnlWireless.Visible = true;
        }
        else
        {
            pnlWireless.Visible = false;
        }
    }

    protected void cbEnableGateway_CheckedChanged(object sender, EventArgs e)
    {
        if (cbEnableGateway.Checked)
        {
            pnlGateway.Visible = true;
        }
        else
        {
            pnlGateway.Visible = false;
        }
    }

    protected void cbDebit_CheckedChanged(object sender, EventArgs e)
    {
        if (cbDebit.Checked)
        {
            pnlDebit.Visible = true;
        }
        else
        {
            pnlDebit.Visible = false;
        }
    }

    private void ShowApplicationUrl(bool isShow)
    {
        trUrl.Visible = isShow;

        if (this.ObjMAOAF != null && this.ObjMAOAF.AgentKey != "")
        {
            string url = String.Format("https://merituspayment.com/applicationxp/applicationxp.aspx?key={0}", this.ObjMAOAF.AgentKey);
            hypURL.NavigateUrl = url;
            hypURL.Text = "Online application";
        }
    }
