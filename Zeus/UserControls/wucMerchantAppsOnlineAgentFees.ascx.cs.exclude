    public string GetBuyRateSummary()
    {
        string ret = "";
        int count = 0;
        StringBuilder sb = new StringBuilder();
        string subject = string.Format("AgentID: {0}, Agent Fee Profile Name: {1}, AgentKey: {2}", this.ObjMAOAF.AgentID.ToString(), this.ObjMAOAF.AgentName, this.ObjMAOAF.AgentKey);
        string title = string.Format("AgentID: {0}<br /> Agent Fee Profile Name: {1}<br /> AgentKey: {2}", this.ObjMAOAF.AgentID.ToString(), this.ObjMAOAF.AgentName, this.ObjMAOAF.AgentKey);
        string header = @"<table>
            <tr>
                <td>Fee Name</td>
                <td>Value</td>
                <td>Buy Rate</td>
            </tr>";

        // split this string on the pipe, and use [0] as the subject in the email.
        sb.Append(string.Format("{0} |<p>{1}</p>{2}", subject, title, header));

        foreach (KeyValuePair<string, string> kvp in this.diFeeMapping)
        {
            // only get them from the database.
            if (kvp.Value != "" && kvp.Key != kvp.Value)
            {

                decimal dVal = this.ObjMAOAF[kvp.Key];
                decimal dFee = this.GetFee(kvp.Key);

                if (dVal < dFee)
                {
                    string template = @"
                        <tr>
                            <td>{0}</td>
                            <td>{1:F2}</td>
                            <td>{2:F2}</td>
                        </tr>";

                    sb.Append(string.Format(template, kvp.Key, dVal, dFee));

                    count++;
                }
            }
        }

        if (count > 0)
        {
            ret = sb.ToString() + "</table>";
        }

        return ret;
    }

