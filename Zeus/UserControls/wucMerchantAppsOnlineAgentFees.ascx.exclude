                    <asp:Label runat="server" Visible="false" CssClass="required" ID="LabVoiceAuthorizationFee"></asp:Label></td>
            </tr>
            <tr>
                <td>
                    Chargeback Fee:</td>
                <td>
                    <ig:WebCurrencyEditor ID="ChargebackFee" runat="server" ValueText="0">
                    </ig:WebCurrencyEditor>
                    <asp:Label runat="server" Visible="false" CssClass="required" ID="LabChargebackFee"></asp:Label></td>
            </tr>
            <tr>
                <td>
                    Service Fee:</td>
                <td>
                    <ig:WebCurrencyEditor ID="ServiceFee" runat="server" ValueText="0">
                    </ig:WebCurrencyEditor>
                    <asp:Label runat="server" Visible="false" CssClass="required" ID="LabServiceFee"></asp:Label></td>
            </tr>
            <tr>
                <td>
                    Application Fee:</td>
                <td>
                    <ig:WebCurrencyEditor ID="ApplicationFee" runat="server" MaxLength="6" ValueText="0">
                    </ig:WebCurrencyEditor>
                    <asp:Label runat="server" Visible="false" CssClass="required" ID="LabApplicationFee"></asp:Label></td>
            </tr>
            <tr>
                <td>
                    ACH Batch Fee:</td>
                <td>
                    <ig:WebCurrencyEditor ID="ACHBatchFee" runat="server" ValueText="0">
                    </ig:WebCurrencyEditor>
                    <asp:Label runat="server" Visible="false" CssClass="required" ID="LabACHBatchFee"></asp:Label></td>
            </tr>
            <tr>
                <td>
                    Retrieval Request Fee:</td>
                <td>
                    <ig:WebCurrencyEditor ID="RetrievalRequestFee" runat="server" ValueText="0">
                    </ig:WebCurrencyEditor>
                    <asp:Label runat="server" Visible="false" CssClass="required" ID="LabRetrievalRequestFee"></asp:Label></td>
            </tr>
            <tr>
                <td>
                    Monthly Minimum Fee:</td>
                <td>
                    <ig:WebCurrencyEditor ID="MonthlyMinimumFee" runat="server" ValueText="0">
                    </ig:WebCurrencyEditor>
                    <asp:Label runat="server" Visible="false" CssClass="required" ID="LabMonthlyMinimumFee"></asp:Label></td>
            </tr>
            <tr>
                <td>
                    Merchant Club Fee:</td>
                <td>
                    <ig:WebCurrencyEditor ID="MerchantClubFee" runat="server" MaxLength="6" ValueText="0">
                    </ig:WebCurrencyEditor>
                    <asp:Label runat="server" Visible="false" CssClass="required" ID="LabMerchantClubFee"></asp:Label></td>
            </tr>
            <tr>
                <td>
                    AVS Voice Auth Fee:</td>
                <td>
                    <ig:WebCurrencyEditor ID="AVSVoiceAuthorizationFee" runat="server" ValueText="0">
                    </ig:WebCurrencyEditor>
                    <asp:Label runat="server" Visible="false" CssClass="required" ID="LabAVSVoiceAuthorizationFee"></asp:Label></td>
            </tr>
            <tr>
                <td>
                    VruARU Fee:</td>
                <td>
                    <ig:WebCurrencyEditor ID="VruARUFee" runat="server" ValueText="0">
                    </ig:WebCurrencyEditor>
                    <asp:Label runat="server" Visible="false" CssClass="required" ID="LabVruARUFee"></asp:Label></td>
            </tr>
        </table>
        <br />
        <div class="title">
            &nbsp;&nbsp;Special Requests
            <hr class="line" />
        </div>
        <br />
        <div style="font-size: 10pt;">
            <i>Describe the equipment to be used here. Also, describe any special pricing or handling
                instructions.</i></div>
        <asp:TextBox runat="server" ID="SpecialRequests" TextMode="MultiLine" Width="100%"
            MaxLength="5000" Height="50"></asp:TextBox>
    </div>
    <div style="clear: both;">
        <!-- -->
    </div>
</asp:Panel>
