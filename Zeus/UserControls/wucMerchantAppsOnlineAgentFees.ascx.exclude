                            <ig:WebCurrencyEditor ID="PINDebitTransactionFee4" runat="server" MaxLength="6"
                                ValueText="0.00">
                            </ig:WebCurrencyEditor>
                            +
                            <ig:WebPercentEditor DataMode="decimal" ID="PINDebitPercentage4" runat="server"
                                ValueText="0.00">
                            </ig:WebPercentEditor>
                            + Network Fees
                        </td>
                    </tr>
                </table>
            </asp:Panel>
        </fieldset>
        <br />
        <div class="title">
            &nbsp;&nbsp;Other Fees
            <hr class="line" />
        </div>
        <table width="100%" cellpadding="5">
            <tr>
                <td style="width: 400px">
