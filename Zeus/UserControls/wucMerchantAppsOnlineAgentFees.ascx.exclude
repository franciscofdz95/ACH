                                <asp:HiddenField runat="server" ID="hidWirelessDataMonthlyFee" />
                                <asp:Label runat="server" Visible="false" CssClass="required" ID="LabWirelessDataMonthlyFee"></asp:Label></td>
                        </tr>
                        <tr>
                            <td>
                                Transaction Fee:</td>
                            <td>
                                <ig:WebCurrencyEditor ID="WirelessTransactionFee" runat="server" ValueText="0">
                                </ig:WebCurrencyEditor>
                                <asp:HiddenField runat="server" ID="hidWirelessTransactionFee" />
                                <asp:Label runat="server" Visible="false" CssClass="required" ID="LabWirelessTransactionFee"></asp:Label></td>
                        </tr>
                    </table>
                </asp:Panel>
            </ContentTemplate>
        </asp:UpdatePanel>
        <fieldset style="display: none;">
            <legend>
                <asp:CheckBox runat="server" ID="cbDebit" Text="Enable PIN-Debit Card Fees" AutoPostBack="true"
                    OnCheckedChanged="cbDebit_CheckedChanged" /></legend>
            <asp:Panel runat="server" ID="pnlDebit" Visible="false">
                <div class="mylabel">
                    Monthly Access Fee:
                </div>
                <table class="cardtypegrid">
                    <tr>
                        <td>
                            <div class="myinput">
                                <div class="mypadding">
                                    <ig:WebCurrencyEditor ID="DebitAccessFee" runat="server" MaxLength="6" ValueText="0">
                                    </ig:WebCurrencyEditor>
                                    <asp:Label runat="server" Visible="false" CssClass="required" ID="LabDebitAccessFee"></asp:Label>
                                </div>
                            </div>
                        </td>
                        <td>
                        </td>
                        <td>
                        </td>
                    </tr>
                </table>
                <div style="clear: both;">
                    <!-- -->
                </div>
                <table class="cardtypegrid">
                    <tr>
                        <td>
                            <asp:RadioButton ID="rblPIN1" runat="server" GroupName="group_pin" />
                            Transaction Fee:
                            <ig:WebCurrencyEditor ID="PINDebitTransactionFee1" runat="server" MaxLength="6"
                                ValueText="0.00">
                            </ig:WebCurrencyEditor>
                            + Networks Fees (Default)
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <asp:RadioButton ID="rblPIN2" runat="server" GroupName="group_pin" />
                            Transaction Fee:
                            <ig:WebCurrencyEditor ID="PINDebitTransactionFee2" runat="server" MaxLength="6"
                                ValueText="0.00">
                            </ig:WebCurrencyEditor>
                            +
                            <ig:WebPercentEditor DataMode="decimal" ID="PINDebitPercentage2" runat="server"
                                ValueText="0.00">
                            </ig:WebPercentEditor>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <asp:RadioButton ID="rblPIN3" runat="server" GroupName="group_pin" />
                            <ig:WebPercentEditor DataMode="decimal" ID="PINDebitPercentage3" runat="server"
                                ValueText="0.00">
                            </ig:WebPercentEditor>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <asp:RadioButton ID="rblPIN4" runat="server" GroupName="group_pin" />
