<%@ Master Language="C#" AutoEventWireup="true" Inherits="MasterPageAgent" CodeBehind="MasterPageAgent.master.cs" %>

<%@ Register Assembly="System.Web.Extensions, Version=1.0.61025.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
    Namespace="System.Web.UI" TagPrefix="asp" %>
<%@ Register Src="UserControls/wucTopMenu.ascx" TagName="wucTopMenu" TagPrefix="uc1" %>
<%@ Register Src="UserControls/wucFooter.ascx" TagName="wucFooter" TagPrefix="uc2" %>
<%@ Register Src="UserControls/wucCommonScripts.ascx" TagName="wucCommonScripts"
    TagPrefix="uc3" %>
<%@ Register Src="UserControls/SidePanel/wucLastTicketsAgent.ascx" TagName="wucLastTicketsAgent"
    TagPrefix="uc4" %>
<%@ Register Src="UserControls/SidePanel/wucRecentlyAccessedPartners.ascx" TagName="wucRecentlyAccessedPartners"
    TagPrefix="uc5" %>
<%@ Register Src="UserControls/wucAgentNotes.ascx" TagName="wucAgentNotes" TagPrefix="uc6" %>
<%@ Register Src="UserControls/wucMessage.ascx" TagName="wucMessage" TagPrefix="uc1" %>
<%@ Register src="UserControls/SidePanel/wucQuickPartnerSearch.ascx" tagname="wucQuickPartnerSearch" tagprefix="uc7" %>
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
    <title>Zeus</title>
    <uc3:wucCommonScripts ID="wucCommonScripts1" runat="server" />
</head>
<body>
    <form id="form1" runat="server">
    <asp:ScriptManager ID="ScriptManager1" runat="server">
    </asp:ScriptManager>

    <uc1:wucTopMenu ID="wucTopMenu1" TopMenuSelect="Partners" runat="server" />
    <table id='zeuslayout'>
        <tr>
            <td class='zleft'>
                <div id="menuside">
                    <asp:Panel ID="pnlSideMenu" CssClass="rounded" runat="server">
                        <ul>
                            <li>
                                <asp:HyperLink ID="lnkSearchAgent" NavigateUrl="~/SecureAgentManagementForms/frmSearchAgents.aspx"
                                    runat="server">Search</asp:HyperLink>
                            </li>
                            <li>
                                <asp:HyperLink ID="lnkAgentProfile" NavigateUrl="~/SecureAgentManagementForms/frmAgent.aspx"
                                    runat="server">Profile</asp:HyperLink>
                            </li>
                            <li>
                                <asp:HyperLink ID="lnkAgentFees" NavigateUrl="~/SecureAgentManagementForms/frmAgentFees.aspx"
                                    runat="server">Fees</asp:HyperLink>
                            </li>
                            <li>
                                <asp:HyperLink ID="lnkAgentSplits" NavigateUrl="~/SecureAgentManagementForms/frmAgentSplits.aspx"
                                    runat="server">Payment Settings</asp:HyperLink>
                            </li>
                            <li>
                                <asp:HyperLink ID="lnkAgentNotes" NavigateUrl="~/SecureAgentManagementForms/frmAgentNotes.aspx"
                                    runat="server">Notes</asp:HyperLink>
                            </li>
                            <li>
                                <asp:HyperLink ID="lnkAgentBanks" NavigateUrl="~/SecureAgentManagementForms/frmAgentBanks.aspx"
                                    runat="server">Banks</asp:HyperLink>
                            </li>
                            <li>
                                <asp:HyperLink ID="lnkMerchantSplits" NavigateUrl="~/SecureAgentManagementForms/frmMerchantSplits.aspx"
                                    runat="server">Merchant Splits</asp:HyperLink>
                            </li>
                            <li>
                                <asp:HyperLink ID="lnkAgentInfo" NavigateUrl="~/SecureAgentManagementForms/frmAgentInfo.aspx"
                                    runat="server">Background</asp:HyperLink>
                            </li>
                            <li>
                                <asp:HyperLink ID="lnkAgentAlerts" NavigateUrl="~/SecureAgentManagementForms/frmAgentAlerts.aspx"
                                    Visible="true" runat="server">Alerts</asp:HyperLink>
                            </li>
                            <li>
                                <asp:HyperLink ID="lnkAgentHistory" NavigateUrl="~/SecureAgentManagementForms/frmAgentHistory.aspx"
                                    runat="server">History</asp:HyperLink>
                            </li>
                            <li>
                                <asp:HyperLink ID="lnkAgentDocuments" NavigateUrl="~/SecureAgentManagementForms/frmAgentDocuments.aspx"
                                    runat="server">Documents</asp:HyperLink>
                            </li>
                            <%-- <li>
                                    <asp:HyperLink ID="lnkOnlineAppFees" NavigateUrl="~/SecureAgentManagementForms/frmMerchantAppsOnlineAgentFees.aspx"
                                        runat="server">Online App Fees</asp:HyperLink>
                                </li>--%>
                            <li>
                                <hr />
                            </li>
                            <li>
                                <asp:LinkButton ID="interlinkApex" OnClick="interlinkApex_Click" runat="server" Text="Open Apex"
                                    CausesValidation="false"></asp:LinkButton>
                            </li>
                        </ul>
                    </asp:Panel>
                </div>
            </td>
            <td class='zmiddle'>
                <uc1:wucMessage ID="WucMessage1" runat="server" />
                <asp:ContentPlaceHolder ID="ContentPlaceHolder1" runat="server">
                
                </asp:ContentPlaceHolder>
            </td>
            <td class='zright'>
                <uc5:wucRecentlyAccessedPartners ID="wucRecentlyAccessedPartners1" runat="server" />
                <uc7:wucQuickPartnerSearch ID="wucQuickPartnerSearch1" runat="server" />
                <uc4:wucLastTicketsAgent ID="wucLastTicketsAgent1" runat="server" />
                <uc6:wucAgentNotes ID="wucAgentNotes1" UsedInSideBar="True" runat="server" />
            </td>
        </tr>
    </table>
    <uc2:wucFooter ID="wucFooter1" runat="server" />
    </form>
</body>
</html>
