    protected void RateBump(object sender, Infragistics.Web.UI.EditorControls.TextEditorValueChangedEventArgs e)
    {
        WebPercentEditor objWCE = (WebPercentEditor)sender;

        Decimal visa_qual = Convert.ToDecimal(objWCE.Value);

        Decimal mid_rate = 0.85m;
        Decimal non_rate = 1.80m;

        VisaMidQualRate.Value = visa_qual + mid_rate;
        VisaNonQualRate.Value = visa_qual + non_rate;

        MCQualRate.Value = visa_qual;
        MCMidQualRate.Value = visa_qual + mid_rate;
        MCNonQualRate.Value = visa_qual + non_rate;

        DiscoverQualRate.Value = visa_qual;
        DiscoverMidQualRate.Value = visa_qual + mid_rate;
        DiscoverNonQualRate.Value = visa_qual + non_rate;

    }

