    public override void FormShow(string ID)
    {

        FormHandler.SetControlEditMode(this.pnlEdit, this.EditMode);

        LoadBanks(MerchantAppTypeUID);

        FormBinding.BindObjectToControls(this.ObjMAOAF, pnlEdit);

        pnlCardType.Visible = false;
        pnlInterchange.Visible = false;
        if (this.ObjMAOAF.PricingType == "t")
        {
            pnlCardType.Visible = true;
        }
        else if (this.ObjMAOAF.PricingType == "i")
        {
            pnlInterchange.Visible = true;
        }




        this.init_buy_rates();

        if (this.ObjMAOAF.PINDebitCardChoice == "")
        {
            pnlDebit.Visible = false;
            cbDebit.Checked = false;

            rblPIN1.Checked = false;
            rblPIN2.Checked = false;
            rblPIN3.Checked = false;
            rblPIN4.Checked = false;

            PINDebitPercentage2.Value = 0.00m;
            PINDebitPercentage3.Value = 0.00m;
            PINDebitPercentage4.Value = 0.00m;
            PINDebitTransactionFee1.Value = 0.00m;
            PINDebitTransactionFee2.Value = 0.00m;
            PINDebitTransactionFee4.Value = 0.00m;
        }
        else
        {
            pnlDebit.Visible = true;
            cbDebit.Checked = true;

            string[] arrChoices = this.ObjMAOAF.PINDebitCardChoice.Split(new char[] { ',' });

            List<string> li = new List<string>();
            foreach (string str in arrChoices)
            {
                if (str != "")
                {
                    li.Add(str.ToLower().Trim());
                }
            }

            rblPIN1.Checked = false;
            rblPIN2.Checked = false;
            rblPIN3.Checked = false;
            rblPIN4.Checked = false;

            PINDebitPercentage2.Value = 0.00m;
            PINDebitPercentage3.Value = 0.00m;
            PINDebitPercentage4.Value = 0.00m;
            PINDebitTransactionFee1.Value = 0.00m;
            PINDebitTransactionFee2.Value = 0.00m;
            PINDebitTransactionFee4.Value = 0.00m;

            if (li.Contains("DebitTransactionFee".ToLower()) && li.Contains("Network".ToLower()) && li.Count == 2)
            {

                rblPIN1.Checked = true;
                PINDebitTransactionFee1.Value = Convert.ToDecimal(this.ObjMAOAF.DebitTransactionFee);
            }
            else if (li.Contains("DebitTransactionFee".ToLower()) && li.Contains("DebitPercentage".ToLower()) && li.Count == 2)
            {
                rblPIN2.Checked = true;
                PINDebitTransactionFee2.Value = Convert.ToDecimal(this.ObjMAOAF.DebitTransactionFee);
                PINDebitPercentage2.Value = Convert.ToDecimal(this.ObjMAOAF.DebitPercentage);
            }
            else if (li.Contains("DebitPercentage".ToLower()) && li.Count == 1)
            {
                rblPIN3.Checked = true;
                PINDebitPercentage3.Value = Convert.ToDecimal(this.ObjMAOAF.DebitPercentage);
            }
            else if (li.Contains("DebitTransactionFee".ToLower()) && li.Contains("DebitPercentage".ToLower()) && li.Contains("Network".ToLower()) && li.Count == 3)
            {
                rblPIN4.Checked = true;
                PINDebitTransactionFee4.Value = Convert.ToDecimal(this.ObjMAOAF.DebitTransactionFee);
                PINDebitPercentage4.Value = Convert.ToDecimal(this.ObjMAOAF.DebitPercentage);
            }
        }

        if (this.ObjMAOAF != null && this.ObjMAOAF.AgentKey != "")
        {
            this.ShowApplicationUrl(true);
        }
        else
        {
            this.ShowApplicationUrl(false);
        }
    }

   
