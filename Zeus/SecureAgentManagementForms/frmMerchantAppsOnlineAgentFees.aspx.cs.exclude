    public IEnumerable ValidateForm()
    {
        if (string.IsNullOrEmpty(AgentName.Text))
        {
            ReqAgentName.IsValid = false;
            yield return ReqAgentName.ErrorMessage;
        }

        string[] str = AgentEmailAddress.Text.Replace(',', ';').Trim().Split(';');
        string strEmails = string.Empty;

        for (int i = 0; i < str.Length; i++)
        {
            if (!(Regex.IsMatch(str[i].Trim(), Constants.EmailRegex)) && str[i].Trim() != "")
                strEmails += str[i].Trim() + ";";
        }

        if (strEmails.TrimEnd(';').Trim().Length > 0)
            yield return "Notification email is invalid. Valid format example: (jdoe@yahoo.com;jdoe@gmail.com)";

        if (PricingType.SelectedValue == "")
        {
            yield return "Please select either 'Tiered Pricing' or 'Interchange'";
        }


        if ((Decimal)VisaQualRate.Value >= 10.0m || (Decimal)VisaQualRate.Value < 0.0m)
        {
            ReqVisaQualRate.IsValid = false;
            yield return ReqVisaQualRate.ErrorMessage;
        }

        if ((Decimal)VisaMidQualRate.Value >= 10.0m || (Decimal)VisaMidQualRate.Value < 0.0m)
        {
            ReqVisaMidQualRate.IsValid = false;
            yield return ReqVisaMidQualRate.ErrorMessage;
        }

        if ((Decimal)VisaNonQualRate.Value >= 10.0m || (Decimal)VisaNonQualRate.Value < 0.0m)
        {
            ReqVisaNonQualRate.IsValid = false;
            yield return ReqVisaNonQualRate.ErrorMessage;
        }

        if ((Decimal)MCQualRate.Value >= 10.0m || (Decimal)MCQualRate.Value < 0.0m)
        {
            ReqMCQualRate.IsValid = false;
            yield return ReqMCQualRate.ErrorMessage;
        }

        if ((Decimal)MCMidQualRate.Value >= 10.0m || (Decimal)MCMidQualRate.Value < 0.0m)
        {
            ReqMCMidQualRate.IsValid = false;
            yield return ReqMCMidQualRate.ErrorMessage;
        }

        if ((Decimal)MCNonQualRate.Value >= 10.0m || (Decimal)MCNonQualRate.Value < 0.0m)
        {
            ReqMCNonQualRate.IsValid = false;
            yield return ReqMCNonQualRate.ErrorMessage;
        }

        if ((Decimal)DiscoverQualRate.Value >= 10.0m || (Decimal)DiscoverQualRate.Value < 0.0m)
        {
            ReqDiscoverQualRate.IsValid = false;
            yield return ReqDiscoverQualRate.ErrorMessage;
        }

        if ((Decimal)DiscoverMidQualRate.Value >= 10.0m || (Decimal)DiscoverMidQualRate.Value < 0.0m)
        {
            ReqDiscoverMidQualRate.IsValid = false;
            yield return ReqDiscoverMidQualRate.ErrorMessage;
        }

        if ((Decimal)DiscoverNonQualRate.Value >= 10.0m || (Decimal)DiscoverNonQualRate.Value < 0.0m)
        {
            ReqDiscoverNonQualRate.IsValid = false;
            yield return ReqDiscoverNonQualRate.ErrorMessage;
        }

        if ((Decimal)ERRVisaDiscount.Value >= 10.0m || (Decimal)ERRVisaDiscount.Value < 0.0m)
        {
            ReqERRVisaDiscount.IsValid = false;
            yield return ReqERRVisaDiscount.ErrorMessage;
        }

        if ((Decimal)ERRVisaNonQualFee.Value >= 10.0m || (Decimal)ERRVisaNonQualFee.Value < 0.0m)
        {
            ReqERRVisaNonQualFee.IsValid = false;
            yield return ReqERRVisaNonQualFee.ErrorMessage;
        }

        if ((Decimal)ERRMCDiscount.Value >= 10.0m || (Decimal)ERRMCDiscount.Value < 0.0m)
        {
            ReqERRMCDiscount.IsValid = false;
            yield return ReqERRMCDiscount.ErrorMessage;
        }

        if ((Decimal)ERRMCNonQualFee.Value >= 10.0m || (Decimal)ERRMCNonQualFee.Value < 0.0m)
        {
            ReqERRMCNonQualFee.IsValid = false;
            yield return ReqERRMCNonQualFee.ErrorMessage;
        }

        if ((Decimal)ERRDiscoverDiscount.Value >= 10.0m || (Decimal)ERRDiscoverDiscount.Value < 0.0m)
        {
            ReqERRDiscoverDiscount.IsValid = false;
            yield return ReqERRDiscoverDiscount.ErrorMessage;
        }

        if ((Decimal)ERRDiscoverNonQualFee.Value >= 10.0m || (Decimal)ERRDiscoverNonQualFee.Value < 0.0m)
        {
            ReqERRDiscoverNonQualFee.IsValid = false;
            yield return ReqERRDiscoverNonQualFee.ErrorMessage;
        }

        if ((Decimal)InterchangePlus.Value >= 10.0m || (Decimal)InterchangePlus.Value < 0.0m)
        {
            ReqInterchangePlus.IsValid = false;
            yield return ReqInterchangePlus.ErrorMessage;
        }

        if (cbDebit.Checked)
        {
            if (rblPIN1.Checked == false && rblPIN2.Checked == false && rblPIN3.Checked == false && rblPIN4.Checked == false)
            {
                yield return "PIN-Debit Card Fees enabled but you must select an option";
            }

        }

        if (PricingType.SelectedValue == "t" && Convert.ToDecimal(VisaQualRate.Value) == 0.00m)
        {
            yield return "If Tiered Pricing is selected, a Qual Rate must be set";
        }

        if (MerchantAppTypeUID.SelectedValue == "-1")
        {
            yield return "Please select a Bank";
        }


    }




    public void BindControlsToObject()
    {
        FormBinding.BindControlsToObject(this.ObjMAOAF, pnlEdit);

        // since this is an integer, we cant store it has a hidden field becaue it expects it to be a string. so we manually set it.
        this.ObjMAOAF.AgentID = UserSessions.CurrentAgent.AgentID;
        this.ObjMAOAF.AgentUID = UserSessions.CurrentAgent.AgentUID;
        this.ObjMAOAF.AgentDBAName = UserSessions.CurrentAgent.AgentDBA;

        // set qual rates
        this.ObjMAOAF.VisaQualRate = Convert.ToDecimal(VisaQualRate.Value);
        VisaQualRate.Value = Convert.ToDecimal(VisaQualRate.Value);
        this.ObjMAOAF.MCQualRate = Convert.ToDecimal(VisaQualRate.Value);
        MCQualRate.Value = Convert.ToDecimal(VisaQualRate.Value);
        this.ObjMAOAF.DiscoverQualRate = Convert.ToDecimal(VisaQualRate.Value);
        DiscoverQualRate.Value = Convert.ToDecimal(VisaQualRate.Value);

        // set mid qual
        this.ObjMAOAF.VisaMidQualRate = Convert.ToDecimal(VisaMidQualRate.Value);
        VisaMidQualRate.Value = Convert.ToDecimal(VisaMidQualRate.Value);
        this.ObjMAOAF.MCMidQualRate = Convert.ToDecimal(VisaMidQualRate.Value);
        MCMidQualRate.Value = Convert.ToDecimal(VisaMidQualRate.Value);
        this.ObjMAOAF.DiscoverMidQualRate = Convert.ToDecimal(VisaMidQualRate.Value);
        DiscoverMidQualRate.Value = Convert.ToDecimal(VisaMidQualRate.Value);

        // set non qual
        this.ObjMAOAF.VisaNonQualRate = Convert.ToDecimal(VisaNonQualRate.Value);
        VisaNonQualRate.Value = Convert.ToDecimal(VisaNonQualRate.Value);
        this.ObjMAOAF.MCNonQualRate = Convert.ToDecimal(VisaNonQualRate.Value);
        MCNonQualRate.Value = Convert.ToDecimal(VisaNonQualRate.Value);
        this.ObjMAOAF.DiscoverNonQualRate = Convert.ToDecimal(VisaNonQualRate.Value);
        DiscoverNonQualRate.Value = Convert.ToDecimal(VisaNonQualRate.Value);

        // set fees
        this.ObjMAOAF.VisaQualFee = Convert.ToDecimal(VisaQualFee.Value);
        VisaQualFee.Value = Convert.ToDecimal(VisaQualFee.Value);
        this.ObjMAOAF.VisaMidQualFee = Convert.ToDecimal(VisaQualFee.Value);
        VisaMidQualFee.Value = Convert.ToDecimal(VisaQualFee.Value);
        this.ObjMAOAF.VisaNonQualFee = Convert.ToDecimal(VisaQualFee.Value);
        VisaNonQualFee.Value = Convert.ToDecimal(VisaQualFee.Value);

        this.ObjMAOAF.MCQualFee = Convert.ToDecimal(VisaQualFee.Value);
        MCQualFee.Value = Convert.ToDecimal(VisaQualFee.Value);
        this.ObjMAOAF.MCMidQualFee = Convert.ToDecimal(VisaQualFee.Value);
        MCMidQualFee.Value = Convert.ToDecimal(VisaQualFee.Value);
        this.ObjMAOAF.MCNonQualFee = Convert.ToDecimal(VisaQualFee.Value);
        MCNonQualFee.Value = Convert.ToDecimal(VisaQualFee.Value);

        this.ObjMAOAF.DiscoverQualFee = Convert.ToDecimal(VisaQualFee.Value);
        DiscoverQualFee.Value = Convert.ToDecimal(VisaQualFee.Value);
        this.ObjMAOAF.DiscoverMidQualFee = Convert.ToDecimal(VisaQualFee.Value);
        DiscoverMidQualFee.Value = Convert.ToDecimal(VisaQualFee.Value);
        this.ObjMAOAF.DiscoverNonQualFee = Convert.ToDecimal(VisaQualFee.Value);
        DiscoverNonQualFee.Value = Convert.ToDecimal(VisaQualFee.Value);


        // set err fee rates for MC and Discover

        this.ObjMAOAF.ERRMCDiscount = Convert.ToDecimal(ERRVisaDiscount.Value);
        this.ObjMAOAF.ERRMCNonQualFee = Convert.ToDecimal(ERRVisaNonQualFee.Value);
        this.ObjMAOAF.ERRMCAuthFee = Convert.ToDecimal(ERRVisaAuthFee.Value);

        ERRMCDiscount.Value = Convert.ToDecimal(ERRVisaDiscount.Value);
        ERRMCNonQualFee.Value = Convert.ToDecimal(ERRVisaNonQualFee.Value);
        ERRMCAuthFee.Value = Convert.ToDecimal(ERRVisaAuthFee.Value);

        this.ObjMAOAF.ERRDiscoverDiscount = Convert.ToDecimal(ERRVisaDiscount.Value);
        this.ObjMAOAF.ERRDiscoverNonQualFee = Convert.ToDecimal(ERRVisaNonQualFee.Value);
        this.ObjMAOAF.ERRDiscoverAuthFee = Convert.ToDecimal(ERRVisaAuthFee.Value);

        ERRDiscoverDiscount.Value = Convert.ToDecimal(ERRVisaDiscount.Value);
        ERRDiscoverNonQualFee.Value = Convert.ToDecimal(ERRVisaNonQualFee.Value);
        ERRDiscoverAuthFee.Value = Convert.ToDecimal(ERRVisaAuthFee.Value);



        this.cbTieredPricing_SelectedIndexChanged(null, null);


        if (cbDebit.Checked)
        {
            if (rblPIN1.Checked)
            {
                this.ObjMAOAF.PINDebitCardChoice = "DebitTransactionFee,Network";
                this.ObjMAOAF.DebitTransactionFee = Convert.ToDecimal(PINDebitTransactionFee1.Value);
                this.ObjMAOAF.DebitPercentage = 0m;
            }
            else if (rblPIN2.Checked)
            {
                this.ObjMAOAF.PINDebitCardChoice = "DebitTransactionFee,DebitPercentage";
                this.ObjMAOAF.DebitTransactionFee = Convert.ToDecimal(PINDebitTransactionFee2.Value);
                this.ObjMAOAF.DebitPercentage = Convert.ToDecimal(PINDebitPercentage2.Value);
            }
            else if (rblPIN3.Checked)
            {
                this.ObjMAOAF.PINDebitCardChoice = "DebitPercentage";
                this.ObjMAOAF.DebitTransactionFee = 0m;
                this.ObjMAOAF.DebitPercentage = Convert.ToDecimal(PINDebitPercentage3.Value);
            }
            else if (rblPIN4.Checked)
            {
                this.ObjMAOAF.PINDebitCardChoice = "DebitTransactionFee,DebitPercentage,Network";
                this.ObjMAOAF.DebitTransactionFee = Convert.ToDecimal(PINDebitTransactionFee4.Value);
                this.ObjMAOAF.DebitPercentage = Convert.ToDecimal(PINDebitPercentage4.Value);
            }

        }
        else
        {
            this.ObjMAOAF.PINDebitCardChoice = "";
            this.ObjMAOAF.DebitTransactionFee = 0m;
            this.ObjMAOAF.DebitPercentage = 0m;
        }

        switch (this.ObjMAOAF.PricingType)
        {
            case "e":
                this.SetZeros_Tiered();
                this.SetZeros_Interchange();
                break;

            case "i":
                this.SetZeros_Tiered();
                this.SetZeros_ERR();
                break;

            case "t":
                this.SetZeros_ERR();
                this.SetZeros_Interchange();
                break;
        }

        this.ObjMAOAF.BuyRateSummary = this.GetBuyRateSummary();
    }

