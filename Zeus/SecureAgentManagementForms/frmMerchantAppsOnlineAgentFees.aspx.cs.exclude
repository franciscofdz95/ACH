    public override void ToggleButtons()
    {
        btnEdit.Enabled = !btnEdit.Enabled;
        btnAdd.Enabled = !btnAdd.Enabled;
        btnSave.Enabled = !btnSave.Enabled;
        btnCancel.Enabled = !btnCancel.Enabled;
        btnRefresh.Enabled = !btnRefresh.Enabled;
        ddlProfiles.Enabled = !ddlProfiles.Enabled;


    }

    public override void FormNew()
    {
        this.Adding = true;
        this.EditMode = true;
        this.FormClear();
        pnlEdit.Visible = true;
        FormHandler.SetControlEditMode(this.pnlEdit, this.EditMode);
        this.ObjMAOAF = new MerchantAppsOnlineAgentFees();
        if (this.ObjMAOAF.AgentKey == "")
        {
            // this means its a new object. so we fill with default fee values from the soft defaults. IRREGARDLESS OF AGENT FEE VALUES from database.
            foreach (KeyValuePair<string, decimal> kvp in this.diDefaultFees)
            {
                this.ObjMAOAF[kvp.Key] = kvp.Value;
            }
        }
        FormBinding.BindObjectToControls(this.ObjMAOAF, pnlEdit);
        LoadBanks(MerchantAppTypeUID);

        this.WebTab1.SelectedIndex = 0;
        this.ToggleButtons();
    }

    public override bool FormSave()
    {
        bool perform = false;


        perform = this.FormDataCheck();


        if (perform)
        {

            this.BindControlsToObject();

            if (this.Adding)
            {

                int rowcount = DataAgent.InsertMerchantAppsOnlineAgentFees(this.ObjMAOAF);

                if (rowcount == 1)
                {
                    WucMessage1.AddMessageStatus("Agent Fee Profile Added");
                    perform = true;
                }
                else
                {
                    if (rowcount == DataAgent.ERRORNUM_EXISTING_PROFILENAME)
                    {
                        WucMessage1.AddMessageError("Profile Name already exists. Please Choose Another.");
                    }
                    else
                    {
                        WucMessage1.AddMessageError("Agent Fee Not Added");
                    }


                }

            }
            else
            {
                int rowcount = DataAgent.UpdateMerchantAppsOnlineAgentFees(this.ObjMAOAF);

                if (rowcount == 1)
                {
                    WucMessage1.AddMessageStatus("Agent Fee Profile Update");
                    perform = true;
                }
                else
                {
                    if (rowcount == DataAgent.ERRORNUM_EXISTING_PROFILENAME)
                    {
                        WucMessage1.AddMessageError("Profile Name already exists. Please Choose Another.");
                    }
                    else
                    {
                        WucMessage1.AddMessageError("Agent Fee Not Updated");
                    }

                }

            }
        }

        return perform;
    }
}
