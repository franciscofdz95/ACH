    public void LoadBanks(ListControl lst)
    {
        Hashtable prms = new Hashtable();
        DataMerchantApp data = DataAccess.DataMerchantAppDao;

        prms.Add("@AgentUID", UserSessions.CurrentAgent.AgentUID);
        prms.Add("@Enable", 1);
        prms.Add("@EnableOnlineApp", 1);

        IList<GenericListItem> banks = data.GetMerchantAppTypesOnline(prms);

        lst.Items.Clear();

        lst.Items.Add(new ListItem("--Select--", "-1"));

        foreach (GenericListItem item in banks)
        {
            lst.Items.Add(new ListItem(item.ItemText, item.ItemValue));
        }
    }

