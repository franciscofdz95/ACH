    public void ToggleButtonsEnableDisable()
    {
        btnEnable.Visible = !UserSessions.CurrentAgent.EnableOnlineApp;
        btnDisable.Visible = UserSessions.CurrentAgent.EnableOnlineApp;
        pnlEdit.Visible = UserSessions.CurrentAgent.EnableOnlineApp;
        pnlSelect.Visible = UserSessions.CurrentAgent.EnableOnlineApp;

        btnEdit.Visible = UserSessions.CurrentAgent.EnableOnlineApp;
        btnAdd.Visible = UserSessions.CurrentAgent.EnableOnlineApp;
        btnSave.Visible = UserSessions.CurrentAgent.EnableOnlineApp;
        btnCancel.Visible = UserSessions.CurrentAgent.EnableOnlineApp;
        btnRefresh.Visible = UserSessions.CurrentAgent.EnableOnlineApp;


    }


    protected void btnEnable_Click(object sender, Infragistics.WebUI.WebDataInput.ButtonEventArgs e)
    {
        DataAgent data = DataAccess.DataAgentDao;

        // get a FRESH COPY from the database of our agent objects. UserSessions.CurrentAgent might be tampered with.
        Agent a = data.GetAgent(UserSessions.CurrentAgent.AgentUID);

        if (a != null)
        {
            a.EnableOnlineApp = true;

            if (data.UpdateAgent(a) > 0)
            {
                UserSessions.CurrentAgent = a;
                this.ToggleButtonsEnableDisable();
                WucMessage1.AddMessageStatus("Agent successfully enabled for Online Apps.");
                LoadOnlineAgents(ddlProfiles, UserSessions.CurrentAgent.AgentID);
            }
            else
            {
                WucMessage1.AddMessageError("Could not update agent.");
            }


        }
        else
        {
            WucMessage1.AddMessageError("Could not find agent.");
        }
    }

    protected void btnDisable_Click(object sender, Infragistics.WebUI.WebDataInput.ButtonEventArgs e)
    {
        DataAgent data = DataAccess.DataAgentDao;

        // get a FRESH COPY from the database of our agent objects. UserSessions.CurrentAgent might be tampered with.
        Agent a = data.GetAgent(UserSessions.CurrentAgent.AgentUID);

        if (a != null)
        {
            a.EnableOnlineApp = false;

            if (data.UpdateAgent(a) > 0)
            {
                UserSessions.CurrentAgent = a;
                this.ToggleButtonsEnableDisable();

                WucMessage1.AddMessageStatus("Agent successfully disabled for Online Apps.");

            }
            else
            {
                WucMessage1.AddMessageError("Could not update agent.");
            }



        }
        else
        {
            WucMessage1.AddMessageError("Could not find agent.");
        }
    }



    ///////////////////////////////////////////////////


    public string GetBuyRateSummary()
    {
        string ret = "";
        int count = 0;
        StringBuilder sb = new StringBuilder();
        string subject = string.Format("AgentID: {0}, Agent Fee Profile Name: {1}, AgentKey: {2}", this.ObjMAOAF.AgentID.ToString(), this.ObjMAOAF.AgentName, this.ObjMAOAF.AgentKey);
        string title = string.Format("AgentID: {0}<br /> Agent Fee Profile Name: {1}<br /> AgentKey: {2}", this.ObjMAOAF.AgentID.ToString(), this.ObjMAOAF.AgentName, this.ObjMAOAF.AgentKey);
        string header = @"<table>
            <tr>
                <td>Fee Name</td>
                <td>Value</td>
                <td>Buy Rate</td>
            </tr>";

        // split this string on the pipe, and use [0] as the subject in the email.
        sb.Append(string.Format("{0} |<p>{1}</p>{2}", subject, title, header));

        foreach (KeyValuePair<string, string> kvp in this.diFeeMapping)
        {
            // only get them from the database.
            if (kvp.Value != "" && kvp.Key != kvp.Value)
            {

                decimal dVal = this.ObjMAOAF[kvp.Key];
                decimal dFee = this.GetFee(kvp.Key);

                if (dVal < dFee)
                {
                    string template = @"
                        <tr>
                            <td>{0}</td>
                            <td>{1:F2}</td>
                            <td>{2:F2}</td>
                        </tr>";

                    sb.Append(string.Format(template, kvp.Key, dVal, dFee));

                    count++;
                }
            }
        }

        if (count > 0)
        {
            ret = sb.ToString() + "</table>";
        }

        return ret;
    }

