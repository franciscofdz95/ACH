                                                                        <asp:Label runat="server" CssClass="required" Visible="false" ID="LabVisaQualFee"></asp:Label>
                                                                    </div>
                                                                    <ig:WebCurrencyEditor ID="VisaMidQualFee" runat="server" ValueText="0" Visible="false">
                                                                    </ig:WebCurrencyEditor>
                                                                    <ig:WebCurrencyEditor ID="VisaNonQualFee" runat="server" ValueText="0" Visible="false">
                                                                    </ig:WebCurrencyEditor>
