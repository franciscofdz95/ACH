                                                            <tr>
                                                                <td colspan="2">
                                                                    <b>Visa / Mastercard / Discover</b></td>
                                                            </tr>
                                                            <tr>
                                                                <td style="width: 200px;">
                                                                    Discount Rate
                                                                </td>
