<%@ Page Language="C#" MasterPageFile="~/MasterPageAgent.master" AutoEventWireup="true"
    CodeFile="frmMerchantAppsOnlineAgentFees.aspx.cs" Inherits="SecureAgentManagementForms_frmMerchantAppsOnlineAgentFees"
    Title="Online Agent Fees" %>

<%@ Register Assembly="Infragistics2.Web.v11.2, Version=11.2.20112.2055, Culture=neutral, PublicKeyToken=7dd5c3163f2cd0cb"
    Namespace="Infragistics.Web.UI.LayoutControls" TagPrefix="ig" %>
<%@ Register Src="../UserControls/wucMessage.ascx" TagName="wucMessage" TagPrefix="uc1" %>
<%@ Register Assembly="Infragistics2.Web.v11.2, Version=11.2.20112.2055, Culture=neutral, PublicKeyToken=7dd5c3163f2cd0cb"
    Namespace="Infragistics.Web.UI.EditorControls" TagPrefix="ig" %>
<%@ Register Assembly="Infragistics2.WebUI.WebDataInput.v11.2, Version=11.2.20112.2055, Culture=neutral, PublicKeyToken=7dd5c3163f2cd0cb"
    Namespace="Infragistics.WebUI.WebDataInput" TagPrefix="igtxt" %>
<%@ Register Assembly="System.Web.Extensions, Version=1.0.61025.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
    Namespace="System.Web.UI" TagPrefix="asp" %>
<asp:Content ID="Content1" ContentPlaceHolderID="ContentPlaceHolder1" runat="Server">
    <div id="contentpage" style="padding: 5px 5px 20px 5px;">
        <asp:Panel runat="server" ID="pnlToolbar" CssClass="tbrtools">
            <div class="tbrtoolsleft">
                <table>
                    <tr>
                        <td>
                            <igtxt:WebImageButton ID="btnAdd" runat="server" Text="Add" CommandName="Add" AccessKey="a"
                                OnClick="tbrTools_ButtonClicked" CausesValidation="False">
                                <Appearance>
                                    <Image Url="~/Images/add2.png" />
                                </Appearance>
                            </igtxt:WebImageButton>
                        </td>
                        <td>
                            <igtxt:WebImageButton ID="btnEdit" runat="server" Text="Edit" CommandName="Edit"
                                AccessKey="e" OnClick="tbrTools_ButtonClicked" CausesValidation="False">
                                <Appearance>
                                    <Image Url="~/Images/edit.png" />
                                </Appearance>
                            </igtxt:WebImageButton>
                        </td>
                        <td>
                            <igtxt:WebImageButton ID="btnSave" runat="server" Text="Save" Enabled="false" AccessKey="s"
                                CausesValidation="False" CommandName="Save" OnClick="tbrTools_ButtonClicked"
                                ClickOnEnterKey="false" ClickOnSpaceKey="false" TabIndex="123">
                                <Appearance>
                                    <Image Url="~/Images/disk_blue.png" />
                                </Appearance>
                                <ClientSideEvents Click="btnSave_Click" />
                            </igtxt:WebImageButton>
                        </td>
                        <td>
                            <igtxt:WebImageButton ID="btnCancel" runat="server" Text="Cancel" Enabled="false"
                                AccessKey="c" CommandName="Cancel" OnClick="tbrTools_ButtonClicked" CausesValidation="False"
                                TabIndex="124">
                                <Appearance>
                                    <Image Url="~/Images/disk_blue_error.png" />
                                </Appearance>
                            </igtxt:WebImageButton>
                        </td>
                        <td>
                            <igtxt:WebImageButton ID="btnRefresh" runat="server" Text="Refresh" CommandName="Refresh"
                                AccessKey="r" OnClick="tbrTools_ButtonClicked" CausesValidation="False" TabIndex="125">
                                <Appearance>
                                    <Image Url="~/Images/refresh.png" />
                                </Appearance>
                            </igtxt:WebImageButton>
                        </td>
                        <td>
                            <igtxt:WebImageButton ID="btnEnable" runat="server" Text="Enable Online Apps" CommandName="EnableApp"
                                OnClick="btnEnable_Click" CausesValidation="False" TabIndex="125">
                            </igtxt:WebImageButton>
                        </td>
                        <td>
                            <igtxt:WebImageButton ID="btnDisable" runat="server" Text="Disable Online Apps for this Agent"
                                CommandName="DisableApp" OnClick="btnDisable_Click" CausesValidation="False"
                                TabIndex="125">
                            </igtxt:WebImageButton>
                        </td>
                    </tr>
                </table>
            </div>
        </asp:Panel>
        <uc1:wucMessage ID="WucMessage1" runat="server"></uc1:wucMessage>
        <asp:Label runat="server" CssClass="title" Style="line-height: 40px;" ID="lblTitle"
            Visible="False"></asp:Label>
        <table>
            <tr>
                <td valign="top">
                    <asp:Panel runat="server" ID="pnlSelect">
                        <div class="title">
                            &nbsp;&nbsp;Agent Fee Profile
                        </div>
                        <asp:ListBox ID="ddlProfiles" runat="server" AutoPostBack="true" OnSelectedIndexChanged="ddlProfiles_SelectedIndexChanged"
                            Height="325px" Width="250px"></asp:ListBox>
                    </asp:Panel>
                </td>
                <td valign="top">
                    <asp:Panel runat="server" ID="pnlEdit">
                        <ig:WebTab ID="WebTab1" runat="server" Width="600px">
                            <Tabs>
                                <ig:ContentTabItem runat="server" Text="Profile">
                                    <Template>
                                        <fieldset>
                                            <table width="100%" cellpadding="2">
                                                <tr>
                                                    <td style="width: 200px">
                                                        Profile Name:</td>
                                                    <td>
                                                        <asp:TextBox runat="server" ID="AgentName"></asp:TextBox>
                                                        <asp:RequiredFieldValidator ID="ReqAgentName" runat="server" ControlToValidate="AgentName"
                                                            ErrorMessage="Profile Name Required">*</asp:RequiredFieldValidator></td>
                                                </tr>
                                                <tr>
                                                    <td style="width: 200px">
                                                        Send notification email to:</td>
                                                    <td>
                                                        <asp:TextBox ID="AgentEmailAddress" runat="server" TextMode="MultiLine" Rows="3"
                                                            Width="200px"></asp:TextBox>
                                                        <asp:RequiredFieldValidator ID="RequiredFieldValidator1" runat="server" ControlToValidate="AgentEmailAddress"
                                                            ErrorMessage="Agent email is required">*</asp:RequiredFieldValidator></td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        Bank:</td>
                                                    <td>
                                                        <asp:DropDownList ID="MerchantAppTypeUID" runat="server">
                                                        </asp:DropDownList></td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        Include ACH:</td>
                                                    <td>
                                                        <asp:CheckBox runat="server" ID="IncludeACH" Text="" /></td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        Production Mode:</td>
                                                    <td>
                                                        <asp:CheckBox runat="server" ID="Enabled" Text="" /></td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        Email Agent</td>
                                                    <td>
                                                        <asp:CheckBox runat="server" ID="EmailAgent" Checked="true" Text="" /></td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        Email Merchant</td>
                                                    <td>
                                                        <asp:CheckBox runat="server" ID="EmailMerchant" Checked="true" Text="" /></td>
                                                </tr>
                                                <tr id="trUrl" runat="server">
                                                    <td>
                                                        Application URL
                                                    </td>
                                                    <td>
                                                        <asp:HyperLink runat="server" Target="_blank" ID="hypURL"></asp:HyperLink>
                                                    </td>
                                                </tr>
                                            </table>
                                        </fieldset>
                                    </Template>
                                </ig:ContentTabItem>
                                <ig:ContentTabItem runat="server" Text="Fees">
