                                                    </div>
                                                    <table class="cardtypegrid">
                                                        <tr>
                                                            <td>
                                                                <asp:RadioButton ID="rblPIN1" runat="server" GroupName="group_pin" />
                                                                Transaction Fee:
                                                                <ig:WebCurrencyEditor ID="PINDebitTransactionFee1" runat="server" MaxLength="6" ValueText="0.00">
