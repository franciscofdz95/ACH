                                                                        ValueText="0">
                                                                    </ig:WebPercentEditor>
                                                                    <asp:CustomValidator ID="ReqMCQualRate" runat="server" ControlToValidate="MCQualRate"
                                                                        ErrorMessage="Mastercard Qual Rate must be less than 10% and must be non-negative">*</asp:CustomValidator>
                                                                </td>
                                                                <td>
