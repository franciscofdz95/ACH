                                                                </td>
                                                                <td>
                                                                    <asp:CustomValidator ID="ReqVisaMidQualRate" runat="server" ControlToValidate="VisaMidQualRate"
                                                                        ErrorMessage="Mid-Qual Rate must be less than 10% and must be non-negative">*</asp:CustomValidator>
                                                                </td>
                                                                <td>
                                                                    <asp:CustomValidator ID="ReqVisaNonQualRate" runat="server" ControlToValidate="VisaNonQualRate"
