                                                                    <asp:CustomValidator ID="ReqMCMidQualRate" runat="server" ControlToValidate="MCMidQualRate"
                                                                        ErrorMessage="Mastercard Mid-Qual Rate must be less than 10% and must be non-negative">*</asp:CustomValidator>
                                                                </td>
                                                                <td>
                                                                    <ig:WebPercentEditor DataMode="decimal" MaxValue="9" ID="MCNonQualRate" runat="server"
                                                                        ValueText="0">
                                                                    </ig:WebPercentEditor>
                                                                    <asp:CustomValidator ID="ReqMCNonQualRate" runat="server" ControlToValidate="MCNonQualRate"
                                                                        ErrorMessage="Mastercard Non-Qual Rate must be less than 10% and must be non-negative">*</asp:CustomValidator>
                                                                </td>
                                                                <td>
                                                                    <div class="mypadding">
                                                                        <ig:WebCurrencyEditor ID="MCQualFee" runat="server" ValueText="0">
                                                                        </ig:WebCurrencyEditor>
                                                                        <asp:Label runat="server" CssClass="required" Visible="false" ID="LabMCQualFee"></asp:Label>
                                                                    </div>
                                                                    <ig:WebCurrencyEditor ID="MCMidQualFee" runat="server" ValueText="0" Visible="false">
                                                                    </ig:WebCurrencyEditor>
                                                                    <ig:WebCurrencyEditor ID="MCNonQualFee" runat="server" ValueText="0" Visible="false">
