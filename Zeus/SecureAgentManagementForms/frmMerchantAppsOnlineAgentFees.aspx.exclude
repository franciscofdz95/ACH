                                                </ContentTemplate>
                                            </asp:UpdatePanel>
                                            <asp:Panel runat="server" ID="pnlHide" Visible="false">
                                                <ig:WebDatePicker ID="EffectiveDate" runat="server" EnableAppStyling="False" NullDateLabel=""
