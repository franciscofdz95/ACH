    public override void FormShow(string ID)
    {
        BindGrid();
        DataMerchantApp data = DataAccess.DataMerchantAppDao;

        ETF objETF = data.GetETFMerchant(ID, "");
        MerchantApp agreement = data.GetMerchantApp(objETF.MerchantAppUID);
        UserSessions.CurrentMerchantApp = agreement;

        FormBinding.BindObjectToControls(agreement, pnlETF);
        FormBinding.BindObjectToControls(objETF, pnlETF);

        SuggestedETF.Text = objETF.SuggestedETF.ToString("c");
        Balance.Text = objETF.Balance.ToString("c");

        FormHandler.SetControlEditMode(pnlDetail, this.EditMode);
        FormHandler.SetControlEditMode(pnlGrid, !this.EditMode);
        FormHandler.SetControlEditMode(WucBusinessInfo1, false);

        FormHandler.ShowClosureCodes(WucBusinessInfo1, agreement.StatusUID.ToUpper());

        lblError.Text = string.Empty;
        if (UserSessions.CurrentUser.AccessLevelUID.ToUpper() != "7B824322-B5A6-4ABF-8810-A29FF271D8B6") // AccessLevel as Manager
            CompareValidator1.Enabled = pnlApprove.Visible = (objETF.ETFStatusUID.ToUpper() == "2835981F-E18D-4844-BC3F-DEA4B60F4081" || objETF.ETFStatusUID.ToUpper() == "A2B6211A-4F6E-4E5B-8A0E-143E4CB4686D");//EXECUTIVE_APPROVAL && MANAGER_APPROVAL

        this.MerchantAppUID = agreement.MerchantAppUID;
        this.MerchantAppZID = agreement.ID;
        this.AccountNumber = agreement.AccountNumber;
        this.RoutingNumber = agreement.RoutingNumber;

        LoadETFStatus();
        LoadInvoices();
    }


    private void LoadInvoices()
    {
        Hashtable prms = new Hashtable();
        prms.Add("@ClientID", this.MerchantAppZID);
        prms.Add("@AchID", ConfigurationManager.AppSettings["AggregatorAchID"]);

        grdACH.SetDataSource(prms, Convert.ToInt32(10));
    }


    public override void FormClear()
    {
        FormHandler.ClearAllControls(pnlGrid);
        ClearGrid();
    }

    public override bool FormSave()
    {
        bool perform = false;
        try
        {
            if (!this.FormDataCheck())
                return false;


            ETF objETF = new ETF();
            DataMerchantApp data = DataAccess.DataMerchantAppDao;
            objETF = data.GetETFMerchant(this.UID, "");

            FormBinding.BindControlsToObject(objETF, pnlETF);

            if (ACHAmount.Text != String.Empty)
                objETF.Balance = objETF.ActualETF - decimal.Parse(ACHAmount.Value.ToString());
            else
                objETF.Balance = objETF.ActualETF;

            User user = UserSessions.CurrentUser;
            objETF.UserUpdated = user.UserName;
            objETF.DateUpdated = DateTime.Now;

            data.UpdateETFMerchant(objETF);
            this.UID = objETF.UID;

            /*if (objETF.ETFStatusUID.ToUpper() == Constants.ETF_ETF_WAIVED)
            {
                MerchantApp app = data.GetMerchantApp(objETF.MerchantAppUID);
                app.ETFAssessed = "W";

                data.UpdateMerchantApp(app);
            }*/

            perform = true;
        }
        catch (Exception exc)
        {
            throw exc;
        }

        if (perform)
        {
            this.EditMode = false;
            this.Adding = false;
            this.ToggleButtons();
            this.FormShow(this.UID);
        }
        else
        {
            lblError.Text = "Record failed to save.";
        }

        return perform;
    }

    public override void FormNew()
    {
        this.FormClear();
        this.Adding = true;
        this.EditMode = true;
        FormHandler.SetControlEditMode(pnlDetail, this.EditMode);
        this.ToggleButtons();
    }

    public override bool FormDelete()
    {
        throw new Exception("The method or operation is not implemented.");
