  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>
  <log4net>
    <appender name="RootLog" type="AchRecurring.SortYearMonthFileAppender">
      <file value="C:\Log\RecurringACH\_" />
      <appendToFile value="true" />
      <rollingStyle value="Date" />
      <maximumFileSize value="64MB" />
      <maxSizeRollBackups value="-1"/>
      <datePattern value="yyyyMMdd'_.log'" />
      <staticLogFileName value="false" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date [%thread] %-5level %method - %message%newline" />
      </layout>
    </appender>
    <logger name="RecurCC.Root">
      <level value="INFO" />
      <appender-ref ref="RootLog" />
    </logger>
  </log4net>
</configuration>
