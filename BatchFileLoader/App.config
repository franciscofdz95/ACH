	</appSettings>
  <log4net>
    <appender name="RootLog" type="PaymentXP.BusinessObjects.Logging.SortYearMonthFileAppender, PaymentXP.BusinessObjects">
      <file value="C:\Log\ACHBatch\_"/>
      <appendToFile value="true"/>
      <rollingStyle value="Date"/>
      <maximumFileSize value="64MB"/>
      <maxSizeRollBackups value="-1"/>
      <datePattern value="yyyyMMdd'_.log'"/>
      <staticLogFileName value="false"/>
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date [%thread] %-5level %method - %message%newline"/>
      </layout>
    </appender>
    <appender name="BatchLog" type="PaymentXP.BusinessObjects.Logging.SortYearMonthFileAppender, PaymentXP.BusinessObjects">
      <file value="C:\Log\ACHBatch\_"/>
      <appendToFile value="true"/>
      <rollingStyle value="Date"/>
      <maximumFileSize value="64MB"/>
      <maxSizeRollBackups value="-1"/>
      <datePattern value="yyyyMMdd'_Batch.log'"/>
      <staticLogFileName value="false"/>
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date [%thread] %-5level %method - %message%newline"/>
      </layout>
    </appender>
    <logger name="Batch.Root">
      <level value="INFO"/>
      <appender-ref ref="RootLog"/>
    </logger>
    <logger name="Batch.Processing">
      <level value="INFO"/>
      <appender-ref ref="RootLog"/>
      <appender-ref ref="BatchLog"/>
    </logger>
  </log4net>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/></startup></configuration>
